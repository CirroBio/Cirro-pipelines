{
    "id": "process-nf-core-sarek-custom-genome-3-5",
    "childProcessIds": [],
    "name": "Variant Calling from FASTQ - Custom Genome",
    "desc": "DNA alignment and variant calling based on GATK4 best practices using a custom FASTA reference",
    "executor": "NEXTFLOW",
    "pipelineTypeOverride": "nf-core",
    "category": "DNA Sequencing",
    "documentationUrl": "https://<DOCS_SITE>/pipelines/catalog-dna-sequencing/#dna-variant-calling-nf-coresarek",
    "code": {
      "repository": "GITHUBPUBLIC",
      "script": "main.nf",
      "uri": "nf-core/sarek",
      "version": "User Defined",
      "executorVersion": "25.10.2"
    },
    "usesSampleSheet": true,
    "fileMappingRules": [
      {
        "description": "Variant Calling VCF",
        "min": 0,
        "fileNamePatterns": [
          {
            "exampleName": "variant_calling/mutect2/sampleName/sampleName.mutect2.variants.vcf.gz",
            "description": "VCF",
            "sampleMatchingPattern": "variant_calling/[^/]+/[^/]+/(?P<sampleName>[\\S ]+?)\\.(?P<caller>[^.]+)\\.variants\\.vcf\\.gz$"
          },
          {
            "exampleName": "variant_calling/mutect2/sampleName/sampleName.mutect2.variants.vcf.gz.tbi",
            "description": "VCF index",
            "sampleMatchingPattern": "variant_calling/[^/]+/[^/]+/(?P<sampleName>[\\S ]+?)\\.(?P<caller>[^.]+)\\.variants\\.vcf\\.gz\\.tbi$"
          }
        ]
      }
    ],
    "computeDefaults": [
      {
        "executor": "NEXTFLOW",
        "json": "s3://<RESOURCES_BUCKET>/<PROCESS_DIRECTORY>/process-compute.config",
        "name": "Default"
      }
    ],
    "paramMapJson": "s3://<RESOURCES_BUCKET>/<PROCESS_DIRECTORY>/process-input.json",
    "preProcessScript": "s3://<RESOURCES_BUCKET>/<PROCESS_DIRECTORY>/preprocess.py",
    "formJson": "s3://<RESOURCES_BUCKET>/<PROCESS_DIRECTORY>/process-form.json",
    "webOptimizationJson": "s3://<RESOURCES_BUCKET>/<PROCESS_DIRECTORY>/process-output.json"
  }
